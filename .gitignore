# dependencies
/node_modules

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*



# vercel
.vercel


# SSL certificates (never commit these!)
ssl/*.pem
ssl/*.key
ssl/*.crt
ssl/*.cert
!ssl/.gitkeep
!ssl/README.md
